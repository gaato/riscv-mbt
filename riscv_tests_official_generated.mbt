///|
pub fn gating_official_riscv_tests() -> Array[OfficialRiscvTestBinary] {
  all_official_riscv_tests().filter(fn(test_case) { test_case.tier == "gating" })
}

///|
pub fn survey_official_riscv_tests() -> Array[OfficialRiscvTestBinary] {
  all_official_riscv_tests().filter(fn(test_case) { test_case.tier == "survey" })
}
